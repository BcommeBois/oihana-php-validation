{
    "name": "oihana/php-validation",
    "type": "library",
    "description": "The Oihana PHP Validation library",
    "keywords": [
        "php",
        "validation",
        "rules",
        "somnambulist",
        "iso8601",
        "i18n"
    ],
    "homepage": "https://github.com/BcommeBois/oihana-php-validation",
    "license": [
        "MPL-2.0"
    ],
    "authors": [
        {
            "name": "Marc Alcaraz",
            "email": "marc@ooop.fr",
            "homepage": "https://www.ooop.fr",
            "role": "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr"
    },
    "autoload": {
        "psr-4": {
            "oihana\\validations\\": "src/oihana/validations"
        },
        "files": [
            "src/oihana/validations/rules/helpers/after.php",
            "src/oihana/validations/rules/helpers/arrayCanOnlyHaveKeys.php",
            "src/oihana/validations/rules/helpers/arrayMustHaveKeys.php",
            "src/oihana/validations/rules/helpers/before.php",
            "src/oihana/validations/rules/helpers/between.php",
            "src/oihana/validations/rules/helpers/date.php",
            "src/oihana/validations/rules/helpers/defaultValue.php",
            "src/oihana/validations/rules/helpers/different.php",
            "src/oihana/validations/rules/helpers/digits.php",
            "src/oihana/validations/rules/helpers/digitsBetween.php",
            "src/oihana/validations/rules/helpers/endsWith.php",
            "src/oihana/validations/rules/helpers/extension.php",
            "src/oihana/validations/rules/helpers/in.php",
            "src/oihana/validations/rules/helpers/length.php",
            "src/oihana/validations/rules/helpers/max.php",
            "src/oihana/validations/rules/helpers/mimes.php",
            "src/oihana/validations/rules/helpers/min.php",
            "src/oihana/validations/rules/helpers/notIn.php",
            "src/oihana/validations/rules/helpers/prohibitedIf.php",
            "src/oihana/validations/rules/helpers/prohibitedUnless.php",
            "src/oihana/validations/rules/helpers/regex.php",
            "src/oihana/validations/rules/helpers/requiredIf.php",
            "src/oihana/validations/rules/helpers/requiredUnless.php",
            "src/oihana/validations/rules/helpers/requiredWith.php",
            "src/oihana/validations/rules/helpers/requiredWithAll.php",
            "src/oihana/validations/rules/helpers/requiredWithout.php",
            "src/oihana/validations/rules/helpers/requiredWithoutAll.php",
            "src/oihana/validations/rules/helpers/requires.php",
            "src/oihana/validations/rules/helpers/rule.php",
            "src/oihana/validations/rules/helpers/rules.php",
            "src/oihana/validations/rules/helpers/same.php",
            "src/oihana/validations/rules/helpers/startsWith.php",
            "src/oihana/validations/rules/helpers/url.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests"
        }
    },
    "require": {
        "php": ">=8.4",
        "oihana/php-core": "dev-main",
        "oihana/php-enums": "dev-main",
        "oihana/php-logging": "dev-main",
        "oihana/php-models": "dev-main",
        "oihana/php-reflect": "dev-main",
        "oihana/php-schema": "dev-main",
        "oihana/php-standards": "dev-main",
        "oihana/php-traits": "dev-main",
        "somnambulist/validation": "^1.12",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "nunomaduro/collision": "^8.8",
        "phpdocumentor/shim": "^3.8",
        "php-di/php-di": "^7.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "doc": "rm -rf docs && mkdir docs && cp -r assets docs/assets && ./vendor/bin/phpdoc -c phpdoc.xml -v",
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html",
        "coverage:md": [
            "@coverage",
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ],
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
